---
import Layout from "../../layouts/Layout.astro";
import { PortableText } from "astro-portabletext"; // El motor de renderizado
import { loadQuery } from "../../sanity/lib/load-query";

// 1. Definimos la interfaz del Post para que TypeScript no se queje
interface Post {
    title: string;
    slug: { current: string };
    publishedAt?: string;
    body?: any; // El contenido enriquecido de Sanity
    resources?: Array<{
        label: string;
        url: string;
        icon: string;
    }>;
}

// 2. Generamos las rutas estáticas para cada post
export async function getStaticPaths() {
    const { data: posts } = await loadQuery<Post[]>({
        query: `*[_type == "post"]`,
    });

    return posts.map((post) => ({
        params: { slug: post.slug.current },
    }));
}

const { slug } = Astro.params;

// 3. Traemos los datos del post específico
const { data: post } = await loadQuery<Post>({
    query: `*[_type == "post" && slug.current == $slug][0]`,
    params: { slug },
});
---

<Layout title={`${post.title} | Paula Quadrelli`} lang="es">
    <article class="post-detail-container">
        <header class="post-header">
            <a href="/blog" class="back-link">← Volver al Blog</a>
            <h1>{post.title}</h1>
            {
                post.publishedAt && (
                    <time datetime={post.publishedAt}>
                        {new Date(post.publishedAt).toLocaleDateString(
                            "es-ES",
                            {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            },
                        )}
                    </time>
                )
            }
        </header>

        <div class="post-body">
            {/* 4. Renderizado dinámico del contenido de Sanity */}
            {
                post.body ? (
                    <PortableText value={post.body} />
                ) : (
                    <p class="placeholder-text">
                        Este post aún no tiene contenido detallado.
                    </p>
                )
            }
        </div>

        {/* 5. Sección de recursos adicionales */}
        {
            post.resources && post.resources.length > 0 && (
                <aside class="post-resources-sidebar">
                    <h3>Recursos Relacionados</h3>
                    <ul>
                        {post.resources.map((res) => (
                            <li>
                                <a
                                    href={res.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <i class={res.icon} /> {res.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </aside>
            )
        }
    </article>
</Layout>

<style>
    .post-detail-container {
        max-width: 900px; /* Un poco más estrecho para mejor lectura */
        margin: 0 auto;
        padding: 150px 20px 80px;
        display: block;
        text-align: left;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent, #686ac4);
        text-decoration: none;
        font-size: 1.2rem;
        font-weight: 500;
        margin-bottom: 2.5rem;
        transition: transform 0.2s ease;
    }

    .back-link:hover {
        transform: translateX(-5px);
    }

    h1 {
        text-wrap: balance;
        font-size: clamp(2.5rem, 6vw, 4rem);
        margin-bottom: 1rem;
        line-height: 1.1;
        color: #ffffff;
    }

    time {
        display: block;
        color: #888;
        font-size: 1rem;
        margin-bottom: 3rem;
    }

    /* ESTILOS PARA EL CONTENIDO DE PORTABLE TEXT */
    .post-body {
        width: 100%;
        font-size: 1.2rem;
        line-height: 1.8;
        color: #e0e0e0;
    }

    /* Estilos inyectados para etiquetas de Sanity */
    .post-body :global(p) {
        margin-bottom: 1.8rem;
    }

    .post-body :global(h2) {
        margin-top: 3rem;
        margin-bottom: 1.2rem;
        color: #ffffff;
        font-size: 2.2rem;
    }

    .post-body :global(ul) {
        margin-bottom: 1.8rem;
        padding-left: 1.5rem;
        list-style: disc;
    }

    .post-body :global(li) {
        margin-bottom: 0.8rem;
    }

    .post-body :global(a) {
        color: var(--accent, #686ac4);
        text-decoration: underline;
    }

    .placeholder-text {
        font-style: italic;
        opacity: 0.6;
    }

    /* SECCIÓN DE RECURSOS */
    .post-resources-sidebar {
        margin-top: 5rem;
        padding-top: 2.5rem;
        border-top: 1px solid #333;
    }

    .post-resources-sidebar h3 {
        font-size: 1.8rem;
        margin-bottom: 2rem;
        color: #ffffff;
    }

    .post-resources-sidebar ul {
        list-style: none;
        padding: 0;
    }

    .post-resources-sidebar li {
        margin-bottom: 1.5rem;
    }

    .post-resources-sidebar a {
        color: #dbdbe0;
        text-decoration: none;
        font-size: 1.4rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.2s ease;
    }

    .post-resources-sidebar a:hover {
        color: var(--accent, #686ac4);
        transform: translateX(8px);
    }
</style>
