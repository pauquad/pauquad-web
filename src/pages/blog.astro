---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog & Resources | Paula Quadrelli" lang="es">

    <section class="blog-container">
        <header class="blog-header-simple">
            <h1>Blog & Recursos</h1>
            <p>Reflexiones sobre diseño sonoro, música y recursos para la comunidad.</p>
        </header>

        <details class="resources-dropdown" open> 
            <summary>Game Audio & Music Resources</summary>
            <div class="resources-content">
                <p>Una colección de herramientas y documentos útiles:</p>
                <ul class="rec-list">
                    <li>
                        <a href="https://docs.google.com/spreadsheets/d/1fcuhGEesLC_PWCwY3dIwLgF774sKswOwIcZECWiH7Xo/edit#gid=0" target="_blank">
                            <i class="fas fa-table"></i> Game Audio Learning Resources (Spreadsheet)
                        </a>
                    </li>
                    <li>
                        <a href="https://docs.google.com/spreadsheets/d/1UEY8T8ClI2XHDnALzWf_x4MZGKoHPNYHlf2CqStSGWQ/edit#gid=337226210" target="_blank">
                            <i class="fas fa-table"></i> Free Audio Resources (Spreadsheet)
                        </a>
                    </li>
                    <li>
                        <a href="https://docs.google.com/document/d/1bE_xuSedxHWBpF9cE7C8hGNWdXjOFdiWXtFGYbqP_30/edit" target="_blank">
                            <i class="fas fa-file-alt"></i> The Game Audio FAQ (Docs)
                        </a>
                    </li>
                    <li>
                        <a href="https://docs.google.com/spreadsheets/d/1JJBlHHDc65fhZmKUGLrDTLCm6rfUU83-kbuD8Y0zU0o/edit#gid=797601028" target="_blank">
                            <i class="fas fa-music"></i> VGM Sound Sources (Spreadsheet)
                        </a>
                    </li>
                </ul>
            </div>
        </details>

        <hr class="divider" />

        <div class="blog-grid">
            <article class="post-card placeholder">
                <div class="post-content">
                    <h2>Próximas entradas...</h2>
                    <p></p>
                </div>
            </article>
        </div>
    </section>

</Layout>