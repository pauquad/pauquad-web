				<div class="form-group">
					<label for="full-name">Nombre</label>
					<input
						type="text"
						id="full-name"
						name="name"
						placeholder="Tu nombre"
						required
					/>
				</div>

				<div class="form-group">
					<label for="email-address">E-mail</label>
					<input
						type="email"
						id="email-address"
						name="email"
						placeholder="Tu E-mail"
						required
					/>
				</div>

				<div class="form-group">
					<label for="message">Mensaje</label>
					<textarea
						id="message"
						name="message"
						rows="6"
						placeholder="Tu mensaje"
						required></textarea>
				</div>

				<input
					type="hidden"
					name="_subject"
					id="email-subject"
					value="Contact Form Submission"
				/>

				<button class="submit-button" type="submit">Enviar</button>
			</form>
		</div>
	</section>

	<script>
		// Usamos una interfaz simple para que TS no se queje del PortableText
		import { toHTML } from "@portabletext/to-html";

		// --- VARIABLES GLOBALES DEL CARRUSEL ---
		// Las sacamos de la función para que todas las sub-funciones tengan acceso
		let selectedItems: HTMLElement[] = [];
		let currentIndex = 0;
		let total = 0;
		let autoPlayInterval: number | undefined;

		function updateCarousel() {
			const dots = document.querySelectorAll(".dot");

			selectedItems.forEach((item, index) => {
				item.classList.remove("left", "center", "right", "side");

				if (index === currentIndex) {
					item.classList.add("center");
				} else if (index === (currentIndex - 1 + total) % total) {
					item.classList.add("side", "left");
				} else if (index === (currentIndex + 1) % total) {
					item.classList.add("side", "right");
				}
			});

			dots.forEach((dot, i) => {
				dot.classList.toggle("active", i === currentIndex);
			});
		}

		const nextSlide = () => {
			currentIndex = (currentIndex + 1) % total;
			updateCarousel();
		};

		const prevSlide = () => {
			currentIndex = (currentIndex - 1 + total) % total;
			updateCarousel();
		};

		function startTimer() {
			autoPlayInterval = window.setInterval(nextSlide, 5000);
		}

		function resetTimer() {
			if (autoPlayInterval) clearInterval(autoPlayInterval);
			startTimer();
		}

		// --- INICIALIZACIÓN DEL CARRUSEL ---
		function initOverlayCarousel() {
			const carousel = document.getElementById(
				"carousel",
			) as HTMLElement | null;
			const dotsContainer = document.getElementById(
				"carousel-dots",
			) as HTMLElement | null;
			const items = Array.from(
				document.querySelectorAll(".carousel-item"),
			) as HTMLElement[];

			if (!carousel || items.length === 0) return;

			// Mezcla aleatoria
			for (let i = items.length - 1; i > 0; i--) {
				const j = Math.floor(Math.random() * (i + 1));
				[items[i], items[j]] = [items[j], items[i]];
			}

			// Selección de 4
			selectedItems = items.slice(0, 4);
			total = selectedItems.length;

			// Limpiar y reinsertar
			carousel.innerHTML = "";
			selectedItems.forEach((item) => carousel.appendChild(item));

			// Generar Dots
			if (dotsContainer) {
				dotsContainer.innerHTML = "";
				selectedItems.forEach((_, i) => {
					const dot = document.createElement("div");
					dot.classList.add("dot");
					if (i === 0) dot.classList.add("active");
					dot.addEventListener("click", () => {
						currentIndex = i;
						updateCarousel();
						resetTimer();
					});
					dotsContainer.appendChild(dot);
				});
			}

			// Eventos de botones
			document
				.getElementById("next-btn")
				?.addEventListener("click", () => {
					nextSlide();
					resetTimer();
				});
			document
				.getElementById("prev-btn")
				?.addEventListener("click", () => {
					prevSlide();
					resetTimer();
				});

			updateCarousel();
			startTimer();
		}

		// --- FORMULARIO DE CONTACTO ---
		function initContactForm() {
			const contactForm = document.querySelector(
				".contact-form",
			) as HTMLFormElement | null;

			if (contactForm) {
				contactForm.addEventListener(
					"submit",
					async (e: SubmitEvent) => {
						e.preventDefault();

						const data = new FormData(contactForm);

						try {
							const response = await fetch(contactForm.action, {
								method: "POST",
								body: data,
								headers: { Accept: "application/json" },
							});

							if (response.ok) {
								contactForm.innerHTML = `
                            <div class="glass-overlay" style="padding: 2rem; border-radius: 15px; text-align: center;">
                                <h3 style="color: white;">¡Mensaje enviado con éxito!</h3>
                                <p style="color: rgba(255,255,255,0.7);">Me pondré en contacto con vos lo antes posible.</p>
                            </div>`;
							} else {
								alert(
									"Hubo un problema al enviar el formulario.",
								);
							}
						} catch (error) {
							alert("Oops! Algo salió mal.");
						}
					},
				);
			}
		}

		// Inicializar todo al cargar el DOM
		document.addEventListener("DOMContentLoaded", () => {
			initOverlayCarousel();
			initContactForm();
		});
	</script>
</Layout>
