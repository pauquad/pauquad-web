	<script>
		function initOverlayCarousel() {
			const carousel = document.getElementById('carousel');
			// 1. Capturamos las 12 imágenes originales (con sus overlays)
			let items = Array.from(document.querySelectorAll('.carousel-item'));
			const dotsContainer = document.getElementById('carousel-dots');
			
			if (items.length === 0) return;

			// 2. MEZCLA ALEATORIA (Shuffle) de las 12
			for (let i = items.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[items[i], items[j]] = [items[j], items[i]];
			}

			// 3. SELECCIÓN DE LAS TOP 4
			// Cortamos el array para quedarnos solo con 4 elementos
			const selectedItems = items.slice(0, 4);

			// Limpiamos el carrusel y solo insertamos las 4 elegidas
			// Como los elementos originales YA tenían el .glass-overlay, 
			// al reinsertarlos, el overlay se mantiene.
			carousel.innerHTML = '';
			selectedItems.forEach(item => carousel.appendChild(item));

			// A partir de aquí, trabajamos solo con las 4 seleccionadas
			let currentIndex = 0;
			const total = selectedItems.length;

			// 4. GENERAR SOLO 4 DOTS
			selectedItems.forEach((_, i) => {
			const dot = document.createElement('div');
			dot.classList.add('dot');
			if (i === 0) dot.classList.add('active');
			dot.addEventListener('click', () => {
				currentIndex = i;
				updateCarousel();
				resetTimer();
			});
			dotsContainer?.appendChild(dot);
			});

			const dots = document.querySelectorAll('.dot');

			function updateCarousel() {
			selectedItems.forEach((item, index) => {
				item.classList.remove('left', 'center', 'right', 'side');
				
				if (index === currentIndex) {
				item.classList.add('center');
				} else if (index === (currentIndex - 1 + total) % total) {
				item.classList.add('side', 'left');
				} else if (index === (currentIndex + 1) % total) {
				item.classList.add('side', 'right');
				}
			});

			dots.forEach((dot, i) => {
				dot.classList.toggle('active', i === currentIndex);
			});
			}

			// --- CONTROLES Y TIMERS ---
			const nextSlide = () => { currentIndex = (currentIndex + 1) % total; updateCarousel(); };
			const prevSlide = () => { currentIndex = (currentIndex - 1 + total) % total; updateCarousel(); };

			document.getElementById('next-btn')?.addEventListener('click', () => { nextSlide(); resetTimer(); });
			document.getElementById('prev-btn')?.addEventListener('click', () => { prevSlide(); resetTimer(); });

			let autoPlayInterval;
			function startTimer() { autoPlayInterval = setInterval(nextSlide, 5000); }
			function resetTimer() { clearInterval(autoPlayInterval); startTimer(); }

			updateCarousel();
			startTimer();
		}

		document.addEventListener('DOMContentLoaded', initOverlayCarousel);

	// FORMULARIO DE CONTACTO

		const contactForm = document.querySelector('.contact-form');
	
	if (contactForm) {
		contactForm.addEventListener('submit', async (e) => {
		e.preventDefault(); // Evita que la página se recargue
		
		const status = document.createElement('p'); // Creamos un mensaje de estado
		status.style.marginTop = "20px";
		status.style.color = "var(--accent-color)"; // Usa tu color de marca
		
		const data = new FormData(contactForm);
		
		try {
			const response = await fetch(contactForm.action, {
			method: 'POST',
			body: data,
			headers: {
				'Accept': 'application/json'
			}
			});
			
			if (response.ok) {
			contactForm.innerHTML = `
				<div class="glass-overlay" style="padding: 2rem; border-radius: 15px; text-align: center;">
				<h3 style="color: white;">¡Mensaje enviado con éxito!</h3>
				<p style="color: rgba(255,255,255,0.7);">Me pondré en contacto con vos lo antes posible.</p>
				</div>`;
			} else {
			const errorData = await response.json();
			alert("Hubo un problema: " + (errorData.errors.map(e => e.message).join(", ")));
			}
		} catch (error) {
			alert("Oops! Algo salió mal al intentar enviar el formulario.");
		}
		});
	}	
	</script>

